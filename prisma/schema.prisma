// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
  output        = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DataSourceType {
  REST_API
  DATABASE
  FILE
}

enum RawDataStatus {
  PENDING
  SUCCESS
  FAILED
}

enum AuditStatus {
  SUCCESS
  FAILED
  WARNING
  INFO
}

model DataSource {
  id   String         @id @default(uuid())
  name String
  type DataSourceType
  provider   String

  connection String?
  baseURL    String

  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  rawData   RawData[]
  symbol Symbol[]
}

model Symbol{
  id              String     @id @default(uuid())
  dataSourceId    String
  ticker          String     // e.g. "BTCUSDT", "AAPL", "BBCA.JK"
  name            String?    // e.g. "Bitcoin / Tether USD"
  defaultInterval String     @default("15m") // e.g. "1m", "1h", "1d"
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  dataSource      DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)

  @@unique([dataSourceId, ticker])
  @@index([ticker, isActive])
}

model RawData {
  id            String          @id @default(uuid())
  dataSourceId  String
  payload       Json
  status        RawDataStatus
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  dataSource    DataSource      @relation(fields: [dataSourceId], references: [id])
  processedData ProcessedData[]
}

model ProcessedData {
  id        String @id @default(uuid())
  rawDataId String

  symbol      String
  granularity String
  timestamp   DateTime

  open   Float
  high   Float
  low    Float
  close  Float
  volume Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rawData RawData @relation(fields: [rawDataId], references: [id])
  // rawData   RawData  @relation(fields: [rawDataId], references: [id])

  @@unique([symbol, granularity, timestamp])
  @@index([symbol, granularity, timestamp])
}

model AuditLog {
  id       String      @id @default(uuid())
  action   String // e.g., "INGEST_YAHOO", "PROCESS_DATA", "CRON_RUN"
  entity   String // e.g., "RawData", "ProcessedData", "DataSource"
  entityId String? // ID terkait (misal rawDataId)
  status   AuditStatus @default(INFO)
  message  String? // Deskripsi
  details  Json? 

  createdAt DateTime @default(now())

  @@index([action, entity])
  @@index([createdAt])
}
